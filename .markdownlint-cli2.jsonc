{
  "config": {
    "default": true,
    "MD013": {
      "line_length": 120,
      "code_blocks": false,
      "tables": false,
      "headings": false,
    },
    "MD024": {
      "siblings_only": true,
    },
    "MD033": false,
  },
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules",
    ".next",
    "test-results",
    "playwright-report",
    "blob-report",
    "docs/superpowers",
    "new-design",
  ],
}
